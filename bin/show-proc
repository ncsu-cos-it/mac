#!/bin/bash
OS=`uname`
BINDIR="/opt/cos/bin"
CONFDIR="/opt/cos/etc"
case $OS in
	Darwin)
		if [ -f "$CONFDIR/PROC.txt" ]; then
		   cat $CONFDIR/PROC.txt
		   exit 0
		else
		   # system_profiler SPHardwareDataType | grep Identifier | awk '{print $3}'  > $CONFDIR/MODEL.txt
		   PROC2=`system_profiler SPHardwareDataType | grep Chip | cut -f2 -d: | sed -e 's/ /_/g'` 
		   PROC=`echo "${PROC2:1}"`
		   echo $PROC > $CONFDIR/PROC.txt
		   chmod 644 $CONFDIR/PROC.txt
		   cat $CONFDIR/PROC.txt
		fi
	;;
	Linux)
		if [ -f "$CONFDIR/MODEL.txt" ]; then
		   cat $CONFDIR/MODEL.txt
		   exit 0
		fi
		if ! [ $LOGNAME = "root" ]; then
                        echo "Need to be root"
                else
			MODEL=`dmidecode -s system-product-name | sed -e 's/ /_/g'`
			echo $MODEL
			echo $MODEL > $CONFDIR/MODEL.txt
			chmod 644 $CONFDIR/MODEL.txt
		fi
	;;
esac	
